. /lib/functions.sh
. /lib/functions/uci-defaults.sh
. /lib/functions/system.sh

board_config_update

case "$(board_name)" in
bananapi,bpi-f3|\
milkv,jupiter)
	ucidef_set_interface_lan_wan 'eth0' 'eth1'
	;;
*)
	ucidef_set_interface_lan 'eth0'
	;;
esac

board_config_flush

exit 0
