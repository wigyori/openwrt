 	/* set iface */
 	snd_soc_component_write(component, WM8960_IFACE1, iface);
 
+	if (audio_format == 0x3) {//TDM Format
+		snd_soc_component_write(component, WM8960_POWER1, 0xfe);
+		snd_soc_component_write(component, WM8960_POWER2, 0x1f8);
