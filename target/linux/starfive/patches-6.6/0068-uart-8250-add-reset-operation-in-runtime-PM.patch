From 6398e60744a8589dea385ddbf49ac66c6c9c0682 Mon Sep 17 00:00:00 2001
From: William Qiu <william.qiu@starfivetech.com>
Date: Wed, 20 Sep 2023 17:19:59 +0800
Subject: [PATCH 068/121] uart: 8250: add reset operation in runtime PM

add reset operation in runtime PM

Signed-off-by: William Qiu <william.qiu@starfivetech.com>
---
 drivers/tty/serial/8250/8250_dw.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/drivers/tty/serial/8250/8250_dw.c b/drivers/tty/serial/8250/8250_dw.c
index 974e04a2570d..389eec85c6ee 100644
--- a/drivers/tty/serial/8250/8250_dw.c
+++ b/drivers/tty/serial/8250/8250_dw.c
@@ -730,6 +730,8 @@ static int dw8250_runtime_suspend(struct device *dev)
 {
 	struct dw8250_data *data = dev_get_drvdata(dev);
 
+	reset_control_assert(data->rst);
+
 	clk_disable_unprepare(data->clk);
 
 	clk_disable_unprepare(data->pclk);
@@ -745,6 +747,8 @@ static int dw8250_runtime_resume(struct device *dev)
 
 	clk_prepare_enable(data->clk);
 
+	reset_control_deassert(data->rst);
+
 	return 0;
 }
 
